rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザーは自身のデータのみアクセス可能
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth.uid == uid;
    }

    // 直接アクセスは禁止（API経由のみ）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
