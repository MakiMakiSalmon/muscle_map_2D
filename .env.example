# ローカル開発時は .env.local に以下をコピーして実値を記入する（.env.local は gitignore 対象）。
# Vercel 本番環境は Vercel プロジェクト設定の Environment Variables で同じキーを設定する。

# ── クライアント側 Firebase 設定（NEXT_PUBLIC_ はブラウザバンドルに埋め込まれる公開値） ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── サーバー側 Firebase Admin SDK 設定（サーバー専用・絶対に公開しない） ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 秘密鍵は1行でエスケープ（\n をリテラル文字列 "\\n" として記述）
FIREBASE_PRIVATE_KEY=
